{** =============================================================================
   QLang 综合 e2e 测试
   涵盖: 全局变量, 数组, 结构体, 矩阵基础, 函数, 控制流, 表达式
   ============================================================================= **}

{** =============================================================================
   1. 全局变量
   ============================================================================= **}
int32 global_counter;
float64 global_pi;

{** =============================================================================
   2. 结构体定义
   ============================================================================= **}
struct Point2D {
    int32 x;
    int32 y;
}

struct Point3D {
    int32 x;
    int32 y;
    int32 z;
}

{** =============================================================================
   3. 辅助函数：阶乘
   ============================================================================= **}
int32 factorial(int32 n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

{** =============================================================================
   4. 辅助函数：数组求和
   ============================================================================= **}
int32 sum_array(int32[5] arr) {
    int32 total;
    total = 0;
    int32 i;
    for (i = 0; i < 5; i = i + 1) {
        total = total + arr[i];
    }
    return total;
}

{** =============================================================================
   5. 辅助函数：创建 Point2D
   ============================================================================= **}
struct Point2D make_point2d(int32 x, int32 y) {
    struct Point2D p;
    p.x = x;
    p.y = y;
    return p;
}

{** =============================================================================
   6. 辅助函数
   ============================================================================= **}
int32 add(int32 a, int32 b) {
    return a + b;
}

int32 get_value() {
    return 42;
}

int32 sum_values(int32 a, int32 b) {
    return a + b;
}

void increment_counter() {
    global_counter = global_counter + 1;
}

{** -------------------------------------------------------------------------
   7. 辅助函数：矩阵单位矩阵
   ------------------------------------------------------------------------- **}
mat<int32> 2x2 make_identity() {
    mat<int32> 2x2 m;
    m[0][0] = 1;
    m[1][1] = 1;
    return m;
}

{** -------------------------------------------------------------------------
   8. 辅助函数：矩阵求迹
   ------------------------------------------------------------------------- **}
int32 matrix_trace(mat<int32> 2x2 mm) {
    return mm[0][0] + mm[1][1];
}

{** =============================================================================
   主函数
   ============================================================================= **}
void main() {
    int32 i;
    int32 result;
    int32[5] numbers;
    struct Point2D p2d;
    struct Point3D p3d;
    mat<int32> 2x2 mat_a;
    mat<int32> 2x2 mat_b;
    mat<int32> 2x2 mat_c;

    {** -------------------------------------------------------------------------
       1. 全局变量赋值和使用
       -------------------------------------------------------------------------- **}
    global_counter = 0;
    global_pi = 3.14159;
    println_int(global_counter);
    println_float64(global_pi);

    {** -------------------------------------------------------------------------
       2. 基础表达式测试
       -------------------------------------------------------------------------- **}
    println_int(100 + 200);
    println_int(50 - 15);
    println_int(7 * 8);
    println_int(40 / 8);
    println_int(25 % 7);
    println_int(-99);

        {** -------------------------------------------------------------------------
       3. 关系运算
       -------------------------------------------------------------------------- **}
    if (10 < 20) { println_int(1); } else { println_int(0); }
    if (10 <= 10) { println_int(1); } else { println_int(0); }
    if (15 > 5) { println_int(1); } else { println_int(0); }
    if (5 >= 5) { println_int(1); } else { println_int(0); }
    if (3 == 3) { println_int(1); } else { println_int(0); }
    if (3 != 4) { println_int(1); } else { println_int(0); }

    {** -------------------------------------------------------------------------
       3a. 逻辑运算
       -------------------------------------------------------------------------- **}
    if (1 && 1) { println_int(1); } else { println_int(0); }
    if (1 || 0) { println_int(1); } else { println_int(0); }
    if (!0) { println_int(1); } else { println_int(0); }

    {** -------------------------------------------------------------------------
       4. 浮点运算
       -------------------------------------------------------------------------- **}
    println_float64(1.5 + 2.5);
    println_float64(10.0 - 3.3);
    println_float64(2.0 * 3.5);
    println_float64(10.0 / 2.5);

    {** -------------------------------------------------------------------------
       5. if-else 控制流
       -------------------------------------------------------------------------- **}
    if (10 > 5) {
        println_int(1);
    } else {
        println_int(0);
    }
    if (3 < 1) {
        println_int(0);
    } else {
        println_int(1);
    }

    {** -------------------------------------------------------------------------
       6. while 循环
       -------------------------------------------------------------------------- **}
    i = 0;
    while (i < 3) {
        println_int(i);
        i = i + 1;
    }

    {** -------------------------------------------------------------------------
       7. for 循环
       -------------------------------------------------------------------------- **}
    for (i = 0; i < 3; i = i + 1) {
        println_int(i);
    }

    {** -------------------------------------------------------------------------
       8. break 和 continue
       -------------------------------------------------------------------------- **}
    i = 0;
    while (i < 10) {
        if (i >= 5) {
            break;
        }
        println_int(i);
        i = i + 1;
    }

    i = 0;
    while (i < 5) {
        i = i + 1;
        if (i == 3) {
            continue;
        }
        println_int(i);
    }

    {** -------------------------------------------------------------------------
       9. switch 语句
       -------------------------------------------------------------------------- **}
    i = 2;
    switch (i) {
        case 1:
            println_int(1);
            break;
        case 2:
            println_int(2);
            break;
        case 3:
            println_int(3);
            break;
        default:
            println_int(0);
            break;
    }

    {** -------------------------------------------------------------------------
       10. 函数调用和递归
       -------------------------------------------------------------------------- **}
    result = factorial(5);
    println_int(result);

    result = add(10, 20);
    println_int(result);

    {** -------------------------------------------------------------------------
       10a. 逻辑运算（含变量）
       -------------------------------------------------------------------------- **}
    if (result >= 0 && result >= 0) { println_int(1); } else { println_int(0); }

    {** -------------------------------------------------------------------------
       11. 数组声明、使用和整体赋值
       -------------------------------------------------------------------------- **}
    numbers[0] = 10;
    numbers[1] = 20;
    numbers[2] = 30;
    numbers[3] = 40;
    numbers[4] = 50;
    println_int(numbers[0]);
    println_int(numbers[4]);

    {** 数组整体赋值测试 **}
    int32[5] numbers_copy;
    numbers_copy = numbers;
    println_int(numbers_copy[0]);
    println_int(numbers_copy[4]);

    {** -------------------------------------------------------------------------
       12. 数组作为函数参数
       -------------------------------------------------------------------------- **}
    result = sum_array(numbers);
    println_int(result);

    {** -------------------------------------------------------------------------
       13. 结构体创建和使用
       -------------------------------------------------------------------------- **}
    p2d.x = 100;
    p2d.y = 200;
    println_int(p2d.x);
    println_int(p2d.y);

    {** -------------------------------------------------------------------------
       14. 结构体作为函数返回值
       -------------------------------------------------------------------------- **}
    p2d = make_point2d(300, 400);
    println_int(p2d.x);
    println_int(p2d.y);

    {** -------------------------------------------------------------------------
       15. 嵌套结构体
       -------------------------------------------------------------------------- **}
    p3d.x = 1;
    p3d.y = 2;
    p3d.z = 3;
    println_int(p3d.x);
    println_int(p3d.y);
    println_int(p3d.z);

    {** -------------------------------------------------------------------------
       16. 矩阵加法
       -------------------------------------------------------------------------- **}
    mat_a[0][0] = 1; mat_a[0][1] = 2;
    mat_a[1][0] = 3; mat_a[1][1] = 4;

    mat_b[0][0] = 5; mat_b[0][1] = 6;
    mat_b[1][0] = 7; mat_b[1][1] = 8;

    mat_c = mat_a + mat_b;
    println_int(mat_c[0][0]);
    println_int(mat_c[0][1]);
    println_int(mat_c[1][0]);
    println_int(mat_c[1][1]);

    {** -------------------------------------------------------------------------
       17. 字符串比较（必须在矩阵运算之后，因为矩阵运算有 codegen bug）
       -------------------------------------------------------------------------- **}
    string s1;
    string s2;
    s1 = "hello";
    s2 = "world";
    if (s1 == s1) {
        println_int(1);
    } else {
        println_int(0);
    }

    {** -------------------------------------------------------------------------
       18. 矩阵减法（字符串之后的矩阵运算可能有问题）
       -------------------------------------------------------------------------- **}
    mat_c = mat_a - mat_b;
    println_int(mat_c[0][0]);
    println_int(mat_c[0][1]);
    println_int(mat_c[1][0]);
    println_int(mat_c[1][1]);

    {** -------------------------------------------------------------------------
       19. 矩阵标量乘法
       -------------------------------------------------------------------------- **}
    int32 scalar;
    scalar = 3;
    mat_c = scalar * mat_a;
    println_int(mat_c[0][0]);
    println_int(mat_c[0][1]);
    println_int(mat_c[1][0]);
    println_int(mat_c[1][1]);

    {** -------------------------------------------------------------------------
       20. 矩阵负运算
       -------------------------------------------------------------------------- **}
    mat_c = -mat_a;
    println_int(mat_c[0][0]);
    println_int(mat_c[0][1]);
    println_int(mat_c[1][0]);
    println_int(mat_c[1][1]);

    {** -------------------------------------------------------------------------
       21. 矩阵乘法
       -------------------------------------------------------------------------- **}
    mat<int32> 2x3 m1;
    mat<int32> 3x2 m2;
    mat<int32> 2x2 mprod;
    m1[0][0] = 1; m1[0][1] = 2; m1[0][2] = 3;
    m1[1][0] = 4; m1[1][1] = 5; m1[1][2] = 6;
    m2[0][0] = 1; m2[0][1] = 2;
    m2[1][0] = 3; m2[1][1] = 4;
    m2[2][0] = 5; m2[2][1] = 6;
    mprod = m1 * m2;
    println_int(mprod[0][0]);
    println_int(mprod[0][1]);
    println_int(mprod[1][0]);
    println_int(mprod[1][1]);

    {** -------------------------------------------------------------------------
       22. 矩阵打印
       -------------------------------------------------------------------------- **}
    println_matrix_int(mat_a);

    {** -------------------------------------------------------------------------
       23. 矩阵作为函数参数和返回值
       -------------------------------------------------------------------------- **}
    mat<int32> 2x2 identity;
    identity = make_identity();
    println_int(identity[0][0]);
    println_int(identity[1][1]);

    {** -------------------------------------------------------------------------
       24. return 语句
       -------------------------------------------------------------------------- **}
    println_int(get_value());
    println_int(sum_values(5, 7));

    {** -------------------------------------------------------------------------
       23. 全局变量修改
       -------------------------------------------------------------------------- **}
    increment_counter();
    increment_counter();
    increment_counter();
    println_int(global_counter);

    {** -------------------------------------------------------------------------
       24. 作用域测试
       -------------------------------------------------------------------------- **}
    int32 scope_test;
    scope_test = 100;
    {
        int32 scope_test;
        scope_test = 200;
        println_int(scope_test);
    }
    println_int(scope_test);

    {** -------------------------------------------------------------------------
       25. 复合表达式
       -------------------------------------------------------------------------- **}
    result = 10 + 20;
    println_int(result * 3);
    result = 100 - 50;
    println_int(result / 5);
}
